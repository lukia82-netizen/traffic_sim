{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Traffic Sim",
  "version": "0.1.0",
  "identifier": "com.trafficsim.app",
  "build": {
    "frontendDist": "../"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Traffic Sim - IDM",
        "width": 800,
        "height": 800,
        "resizable": true,
        "devtools": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": []
  }
}
